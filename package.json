{
  "name": "project-workbench",
  "version": "1.0.3",
  "private": true,
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --webpack",
    "build": "prisma generate && prisma migrate deploy && next build",
    "db:deploy": "prisma migrate deploy && prisma db seed",
    "db:migrate": "npx tsx scripts/migrate-with-app-env.ts",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run __tests__/lib",
    "test:watch": "vitest",
    "migrate:split-week-actuals": "npx tsx scripts/migrate-split-week-actuals.ts"
  },
  "dependencies": {
    "@fontsource/raleway": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@react-pdf/renderer": "^4.3.2",
    "@tanstack/react-table": "^8.21.3",
    "@trigger.dev/sdk": "^4.4.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.3.1",
    "@vercel/speed-insights": "^1.3.1",
    "bcryptjs": "^3.0.3",
    "dompurify": "^3.3.3",
    "html2canvas-pro": "^2.0.2",
    "isomorphic-dompurify": "^3.3.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "pg": "^8.18.0",
    "prisma": "^7.4.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
